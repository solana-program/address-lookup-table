{
    "idl": "program/idl.json",
    "before": [],
    "scripts": {
        "js": {
            "from": "@codama/renderers-js",
            "args": [
                "clients/js",
                {
                    "kitImportStrategy": "rootOnly",
                    "syncPackageJson": true
                }
            ]
        },
        "rust": {
            "from": "@codama/renderers-rust",
            "args": [
                "clients/rust",
                {
                    "anchorTraits": false,
                    "formatCode": true,
                    "toolchain": "+nightly-2026-01-22"
                }
            ]
        }
    }
}
